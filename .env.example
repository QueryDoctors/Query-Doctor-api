# Copy to .env.local / .env.dev / .env.prod and fill in values.
# Active env file is chosen by the ENV variable or by symlinking .env → .env.<name>

ENV=local                          # local | dev | prod

# App database — where the advisor stores saved connections + snapshots
APP_DATABASE_URL=postgresql://postgres:secret@localhost:5432/advisor_app

# Fernet encryption key for stored passwords
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

APP_HOST=0.0.0.0
APP_PORT=8000

DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

CORS_ORIGINS=["http://localhost:3000"]
